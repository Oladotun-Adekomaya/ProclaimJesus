# ── Azure AI Video Indexer ────────────────────────────────────────────────────
# Get these from https://api-portal.videoindexer.ai/
# Use the trial account values for free-tier (2,400 min/month)
AZURE_VI_ACCOUNT_ID=
AZURE_VI_LOCATION=trial
AZURE_VI_API_KEY=

# Optional: ARM-based auth (needed for production accounts, not trial)
AZURE_VI_SUBSCRIPTION_ID=
AZURE_VI_RESOURCE_GROUP=
AZURE_VI_TENANT_ID=
AZURE_VI_CLIENT_ID=
AZURE_VI_CLIENT_SECRET=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=
