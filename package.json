{
  "name": "proclaim-jesus",
  "version": "0.1.0",
  "private": true,
  "description": "ProclaimJesus — AI-powered sermon clipper for church media teams",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "electron .",
    "dev:backend": "cd backend && .venv/bin/python3 -m uvicorn main:app --reload --port 8642",
    "build": "cd frontend && npm run build && electron-builder",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "python-shell": "^5.0.0"
  },
  "build": {
    "appId": "com.proclaimjesus.app",
    "productName": "ProclaimJesus",
    "copyright": "Copyright © 2025 ProclaimJesus",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "shared/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
